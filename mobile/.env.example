# Скопируйте в .env для локальной разработки:  copy .env.example .env

# --- Продакшен (Android + iOS) — в .env.production: https://runbonus.online ---
# VITE_API_URL=https://runbonus.online

# --- iOS: симулятор на Mac использует localhost автоматически в dev ---
# iPhone + локальный backend: VITE_API_URL=http://192.168.x.x:3001

# --- Dev в браузере: прокси Vite (без CORS), не задавайте VITE_API_URL ---
# VITE_API_PROXY=http://runbonus.online

# --- Разработка: браузер на ПК ---
# VITE_API_URL=http://localhost:3001

# --- Разработка: телефон по Wi‑Fi (IP ПК из ipconfig) ---
# VITE_API_URL=http://192.168.x.x:3001

# --- Только эмулятор Android (без .env) ---
# VITE_API_URL=http://10.0.2.2:3001
