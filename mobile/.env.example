# Скопируйте в .env перед сборкой Android:  copy .env.example .env

# Браузер на ПК:
# VITE_API_URL=http://localhost:3001

# Телефон по USB/Wi‑Fi (IP ПК из ipconfig, телефон и ПК в одной Wi‑Fi):
VITE_API_URL=http://192.168.223.30:3001

# Только эмулятор Android (без .env подставится 10.0.2.2 автоматически):
# VITE_API_URL=http://10.0.2.2:3001
