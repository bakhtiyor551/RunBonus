{
	"appId": "com.runbonus.app",
	"appName": "RunBonus",
	"webDir": "dist",
	"server": {
		"androidScheme": "http",
		"iosScheme": "http"
	},
	"android": {
		"allowMixedContent": true
	},
	"ios": {
		"contentInset": "automatic",
		"allowsLinkPreview": false
	},
	"plugins": {
		"CapacitorHttp": {
			"enabled": true
		},
		"Geolocation": {
			"permissions": [
				"location",
				"coarseLocation"
			]
		}
	}
}
