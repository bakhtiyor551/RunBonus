{
  "name": "runbonus-mobile",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host",
    "build": "vite build --mode production",
    "build:release": "vite build --mode production && npx cap sync",
    "build:ios": "vite build --mode production && npx cap sync ios",
    "preview": "vite preview",
    "cap:sync": "npm run build && npx cap sync",
    "cap:android": "npm run cap:sync && npx cap run android",
    "cap:ios": "npm run cap:sync && npx cap sync ios",
    "cap:open": "npx cap open android",
    "cap:open:ios": "npx cap open ios",
    "icons": "node scripts/generate-icons.mjs && npx @capacitor/assets generate --iconBackgroundColor \"#131313\" --splashBackgroundColor \"#131313\"",
    "sms-hash": "node scripts/android-sms-hash.mjs"
  },
  "dependencies": {
    "@capacitor-community/admob": "^7.2.0",
    "@capacitor/android": "^6.1.2",
    "@capacitor/app": "^6.0.3",
    "@capacitor/core": "^6.1.2",
    "@capacitor/geolocation": "^6.0.1",
    "@capacitor/ios": "^6.2.1",
    "@capacitor/keyboard": "^6.0.4",
    "@capacitor/network": "^6.0.4",
    "@capacitor/status-bar": "^6.0.3",
    "@ionic/react": "^8.3.2",
    "html5-qrcode": "^2.3.8",
    "ionicons": "^7.4.0",
    "leaflet": "^1.9.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-leaflet": "^4.2.1",
    "react-router-dom": "^6.26.2"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^6.1.2",
    "@vitejs/plugin-react": "^4.3.1",
    "sharp": "^0.34.5",
    "vite": "^5.4.8"
  }
}
