PORT=3001
DB_HOST=localhost
DB_PORT=3306
DB_USER=runbonus
DB_PASSWORD=runbonus
DB_NAME=runbonus
JWT_SECRET=change-me-in-production
JWT_ADMIN_SECRET=change-admin-secret
BONUS_PER_KM=3
DAILY_BONUS_LIMIT=10
SHOE_BONUS_LIMIT=200

# Telegram — уведомления о заявках на вывод и заказах (фото чека)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Публичный адрес API (для отправки чека в Telegram по URL, если нужно)
PUBLIC_API_URL=https://runbonus.online

# SMS (OsonSMS) — регистрация и вход по коду
SMS_LOGIN=
SMS_TOKEN=
SMS_SENDER=RunBonus
SMS_SERVER=https://api.osonsms.com
# SMS_DEV_CODE=123456
# Хеш Android для автоподстановки кода (11 символов): cd mobile && node scripts/android-sms-hash.mjs
# SMS_APP_HASH=

# Firebase Cloud Messaging (push-уведомления в приложении)
# Скачайте service account: Firebase Console → Project settings → Service accounts → Generate new private key
# FIREBASE_SERVICE_ACCOUNT_PATH=secrets/firebase-service-account.json
# или одной строкой JSON:
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
